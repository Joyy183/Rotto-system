# ─────────────────────────────────────────────
#  ROTTO SYSTEM – Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/rotto_system

# JWT secret – change this to a long random string in production!
JWT_SECRET=rotto_super_secret_key_change_in_production_2026

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Admin emails (comma-separated, no spaces)
ADMIN_EMAILS=adminrotto2026@gmail.com,adminkitch2026@gmail.com

# CORS – set to your frontend URL in production
CORS_ORIGIN=*
